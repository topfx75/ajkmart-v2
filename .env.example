# ============================================================
#  AJKMart - Environment Variables Template
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# DATABASE (Required)
# ------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/ajkmart

# ------------------------------------------------------------
# API SERVER
# ------------------------------------------------------------
PORT=3000
NODE_ENV=production

# Admin secret key (used for migrations and protected admin APIs)
# Generate with: openssl rand -hex 32
ADMIN_SECRET=change_this_to_a_strong_random_secret

# Comma-separated list of allowed frontend origins
# Example: https://yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# ------------------------------------------------------------
# FRONTEND / WEB APPS (Vite)
# ------------------------------------------------------------
# Base URL of your deployed API server
VITE_API_URL=http://localhost:3000/api
VITE_API_BASE_URL=http://localhost:3000

# Set to "true" when building for native Android/iOS with Capacitor
VITE_CAPACITOR=false

# ------------------------------------------------------------
# MOBILE APP (Expo)
# ------------------------------------------------------------
# Your server domain (without trailing slash)
EXPO_PUBLIC_DOMAIN=http://localhost:3000

# Google OAuth Client ID (for Google Sign-In)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Facebook App ID (for Facebook Sign-In)
EXPO_PUBLIC_FB_APP_ID=your_facebook_app_id_here

# ------------------------------------------------------------
# SMS / OTP (Configured in Admin Panel after setup)
# These can also be set directly in the platform_settings table
# ------------------------------------------------------------
# Twilio (if using Twilio for SMS)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# MSG91 (if using MSG91 for Pakistan SMS)
# MSG91_API_KEY=your_msg91_api_key

# ------------------------------------------------------------
# EMAIL (Optional - for email notifications)
# ------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# ------------------------------------------------------------
# WEB PUSH NOTIFICATIONS (Auto-generated on first run)
# ------------------------------------------------------------
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_MAILTO=mailto:admin@yourdomain.com

# ------------------------------------------------------------
# AI / OPENAI (Optional - for AI features)
# ------------------------------------------------------------
# OPENAI_API_KEY=sk-your_openai_api_key_here
